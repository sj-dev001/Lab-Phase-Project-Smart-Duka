NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database - MongoDB Atlas (free tier)
# Get connection string from https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/smartduka

JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# Payment - Paystack (free tier available at https://paystack.com)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxx

# File Upload - Uploadthing (free tier available at https://uploadthing.com)
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxxxxxxxxxx
